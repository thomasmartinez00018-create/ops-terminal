# ============================================================================
# OPS TERMINAL — BACKEND ENV TEMPLATE
# ============================================================================
# Copiá este archivo a packages/backend/.env y completá los valores.
# .env NO se commitea (está en .gitignore). Usá este archivo para
# documentar qué variables necesita el backend para arrancar.
# ============================================================================

# DB (Postgres en Neon para prod, SQLite local para dev)
DATABASE_URL="file:./data/stock-gastro.db"

# JWT (obligatorio en prod, random en dev)
JWT_SECRET=""

# CORS — lista separada por comas de dominios permitidos
ALLOWED_ORIGINS="https://ops-terminal-alpha.vercel.app,https://app.opsterminal.com"

# Frontend URL — usada en back_url de Mercado Pago
FRONTEND_URL="https://ops-terminal-alpha.vercel.app"

# ============================================================================
# MERCADO PAGO
# ============================================================================
# MP_MODE controla qué set de credenciales usa:
#   test → sandbox, no cobra plata real
#   production → cobra plata real
MP_MODE="test"

# Credenciales de prueba (panel MP → Credenciales de prueba)
MP_ACCESS_TOKEN_TEST=""
MP_PUBLIC_KEY_TEST=""

# Credenciales de producción (panel MP → Credenciales de producción)
# ⚠️ Con MP_MODE=production cualquier subscribe cobra plata real.
MP_ACCESS_TOKEN_PROD=""
MP_PUBLIC_KEY_PROD=""
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""

# Google Gemini (para escaneo de facturas)
GEMINI_API_KEY=""
