generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "darwin", "darwin-arm64"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// MAESTRO DE PRODUCTOS
// ==========================================
model Producto {
  id                Int      @id @default(autoincrement())
  codigo            String   @unique
  nombre            String
  rubro             String   // Verduras, Carnes, Lacteos, Bebidas, etc.
  tipo              String   // crudo, elaborado, semielaborado, insumo
  unidadCompra      String   @map("unidad_compra")  // kg, lt, unidad, caja
  unidadUso         String   @map("unidad_uso")     // kg, lt, unidad, porcion
  factorConversion  Float    @default(1) @map("factor_conversion")
  codigoBarras      String?  @map("codigo_barras")
  depositoDefectoId Int?     @map("deposito_defecto_id")
  stockMinimo       Float    @default(0) @map("stock_minimo")
  stockIdeal        Float    @default(0) @map("stock_ideal")
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  depositoDefecto     Deposito?            @relation(fields: [depositoDefectoId], references: [id])
  movimientos         Movimiento[]
  proveedorProductos  ProveedorProducto[]
  recetaIngredientes  RecetaIngrediente[]
  inventarioDetalles  InventarioDetalle[]
  ordenCompraItems    OrdenCompraItem[]
  recepcionItems      RecepcionItem[]
  recetasResultado    Receta[]             @relation("recetaProducto")
  elaboraciones       ElaboracionLote[]    @relation("elaborProducto")

  @@map("productos")
}

// ==========================================
// DEPÓSITOS
// ==========================================
model Deposito {
  id     Int     @id @default(autoincrement())
  codigo String  @unique
  nombre String
  tipo   String? // almacen, cocina, barra, freezer, camara, seco
  activo Boolean @default(true)

  productos            Producto[]
  movimientosOrigen    Movimiento[] @relation("depositoOrigen")
  movimientosDestino   Movimiento[] @relation("depositoDestino")
  inventarios          Inventario[]
  ordenesCompra        OrdenCompra[] @relation("ocDeposito")
  usuariosDefecto      Usuario[]    @relation("usuarioDepositoDefecto")
  elaboraciones        ElaboracionLote[] @relation("elaborDeposito")

  @@map("depositos")
}

// ==========================================
// USUARIOS
// ==========================================
model Usuario {
  id       Int     @id @default(autoincrement())
  codigo   String  @unique
  nombre   String
  rol      String  // admin, cocina, deposito, barra, compras
  pin      String?
  activo   Boolean @default(true)
  permisos String  @default("[]") // JSON array de claves de secciones habilitadas

  depositoDefectoId        Int?     @map("deposito_defecto_id")
  depositoDefecto          Deposito? @relation("usuarioDepositoDefecto", fields: [depositoDefectoId], references: [id])

  movimientos              Movimiento[] @relation("movUsuario")
  movimientosResponsable   Movimiento[] @relation("movResponsable")
  inventarios       Inventario[]
  ordenesCreadas    OrdenCompra[] @relation("ocCreador")
  ordenesAsignadas  OrdenCompra[] @relation("ocResponsable")
  recepciones       Recepcion[]   @relation("recepcionUsuario")
  tareasCreadas     Tarea[]       @relation("tareasCreadas")
  tareasAsignadas   Tarea[]       @relation("tareasAsignadas")
  elaboraciones     ElaboracionLote[] @relation("elaborUsuario")

  @@map("usuarios")
}

// ==========================================
// MOVIMIENTOS (corazón del sistema)
// ==========================================
model Movimiento {
  id               Int      @id @default(autoincrement())
  fecha            String   // YYYY-MM-DD
  hora             String   // HH:mm
  usuarioId        Int      @map("usuario_id")
  tipo             String   // ingreso, elaboracion, merma, transferencia, ajuste, conteo, consumo_interno, devolucion
  depositoOrigenId  Int?    @map("deposito_origen_id")
  depositoDestinoId Int?    @map("deposito_destino_id")
  productoId       Int      @map("producto_id")
  cantidad         Float
  unidad           String
  lote             String?
  motivo           String?
  costoUnitario    Float?   @map("costo_unitario")
  proveedorId      Int?     @map("proveedor_id")
  documentoRef     String?  @map("documento_ref")
  observacion      String?
  responsableId    Int?     @map("responsable_id")
  recepcionId      Int?     @map("recepcion_id")
  elaboracionLoteId Int?    @map("elaboracion_lote_id")
  createdAt        DateTime @default(now()) @map("created_at")

  usuario          Usuario          @relation("movUsuario", fields: [usuarioId], references: [id])
  responsable      Usuario?         @relation("movResponsable", fields: [responsableId], references: [id])
  depositoOrigen   Deposito?        @relation("depositoOrigen", fields: [depositoOrigenId], references: [id])
  depositoDestino  Deposito?        @relation("depositoDestino", fields: [depositoDestinoId], references: [id])
  producto         Producto         @relation(fields: [productoId], references: [id])
  proveedor        Proveedor?       @relation(fields: [proveedorId], references: [id])
  recepcion        Recepcion?       @relation(fields: [recepcionId], references: [id])
  elaboracionLote  ElaboracionLote? @relation(fields: [elaboracionLoteId], references: [id])

  @@map("movimientos")
}

// ==========================================
// PROVEEDORES
// ==========================================
model Proveedor {
  id       Int     @id @default(autoincrement())
  codigo   String  @unique
  nombre   String
  contacto String?
  telefono String?
  email    String?
  activo   Boolean @default(true)

  movimientos        Movimiento[]
  proveedorProductos ProveedorProducto[]
  ordenesCompra      OrdenCompra[]

  @@map("proveedores")
}

// ==========================================
// PRODUCTOS DEL PROVEEDOR (normalización)
// ==========================================
model ProveedorProducto {
  id               Int     @id @default(autoincrement())
  proveedorId      Int     @map("proveedor_id")
  productoId       Int     @map("producto_id")
  nombreProveedor  String  @map("nombre_proveedor") // "Papa negra x 10kg"
  codigoProveedor  String? @map("codigo_proveedor")
  unidadProveedor  String? @map("unidad_proveedor")
  factorConversion Float   @default(1) @map("factor_conversion")
  ultimoPrecio     Float?  @map("ultimo_precio")
  fechaPrecio      String? @map("fecha_precio")

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  producto  Producto  @relation(fields: [productoId], references: [id])

  @@map("proveedor_productos")
}

// ==========================================
// RECETAS
// ==========================================
model Receta {
  id                  Int     @id @default(autoincrement())
  codigo              String  @unique
  nombre              String
  categoria           String? // entrada, plato, postre, bebida
  porciones           Int     @default(1)
  productoResultadoId Int?    @map("producto_resultado_id")
  cantidadProducida   Float?  @map("cantidad_producida")
  unidadProducida     String? @map("unidad_producida")
  activo              Boolean @default(true)

  ingredientes      RecetaIngrediente[]
  elaboraciones     ElaboracionLote[]
  productoResultado Producto? @relation("recetaProducto", fields: [productoResultadoId], references: [id])

  @@map("recetas")
}

// ==========================================
// INGREDIENTES DE RECETA
// ==========================================
model RecetaIngrediente {
  id             Int   @id @default(autoincrement())
  recetaId       Int   @map("receta_id")
  productoId     Int   @map("producto_id")
  cantidad       Float
  unidad         String
  mermaEsperada  Float @default(0) @map("merma_esperada") // porcentaje

  receta   Receta   @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@map("receta_ingredientes")
}

// ==========================================
// ELABORACION LOTES
// ==========================================
model ElaboracionLote {
  id                  Int      @id @default(autoincrement())
  codigo              String   @unique
  fecha               String
  hora                String
  usuarioId           Int      @map("usuario_id")
  recetaId            Int?     @map("receta_id")
  productoResultadoId Int      @map("producto_resultado_id")
  cantidadProducida   Float    @map("cantidad_producida")
  unidadProducida     String   @map("unidad_producida")
  depositoDestinoId   Int?     @map("deposito_destino_id")
  observacion         String?
  createdAt           DateTime @default(now()) @map("created_at")

  usuario           Usuario   @relation("elaborUsuario", fields: [usuarioId], references: [id])
  receta            Receta?   @relation(fields: [recetaId], references: [id])
  productoResultado Producto  @relation("elaborProducto", fields: [productoResultadoId], references: [id])
  depositoDestino   Deposito? @relation("elaborDeposito", fields: [depositoDestinoId], references: [id])
  movimientos       Movimiento[]

  @@map("elaboracion_lotes")
}

// ==========================================
// INVENTARIOS / CONTEOS
// ==========================================
model Inventario {
  id          Int      @id @default(autoincrement())
  fecha       String   // YYYY-MM-DD
  usuarioId   Int      @map("usuario_id")
  depositoId  Int      @map("deposito_id")
  estado      String   @default("abierto") // abierto, cerrado
  observacion String?
  createdAt   DateTime @default(now()) @map("created_at")

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  deposito Deposito @relation(fields: [depositoId], references: [id])
  detalles InventarioDetalle[]

  @@map("inventarios")
}

model InventarioDetalle {
  id             Int    @id @default(autoincrement())
  inventarioId   Int    @map("inventario_id")
  productoId     Int    @map("producto_id")
  cantidadFisica Float  @map("cantidad_fisica")
  stockTeorico   Float? @map("stock_teorico")
  diferencia     Float? // fisica - teorica
  observacion    String?

  inventario Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  producto   Producto   @relation(fields: [productoId], references: [id])

  @@map("inventario_detalles")
}

// ==========================================
// ÓRDENES DE COMPRA
// ==========================================
model OrdenCompra {
  id                Int      @id @default(autoincrement())
  codigo            String   @unique          // OC-001
  fecha             String                    // YYYY-MM-DD
  estado            String   @default("pendiente") // pendiente, parcial, recibida, cancelada
  proveedorId       Int      @map("proveedor_id")
  creadoPorId       Int      @map("creado_por_id")
  responsableId     Int      @map("responsable_id")
  depositoDestinoId Int?     @map("deposito_destino_id")
  observacion       String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  proveedor       Proveedor @relation(fields: [proveedorId], references: [id])
  creadoPor       Usuario   @relation("ocCreador", fields: [creadoPorId], references: [id])
  responsable     Usuario   @relation("ocResponsable", fields: [responsableId], references: [id])
  depositoDestino Deposito? @relation("ocDeposito", fields: [depositoDestinoId], references: [id])
  items           OrdenCompraItem[]
  recepciones     Recepcion[]

  @@map("ordenes_compra")
}

model OrdenCompraItem {
  id             Int    @id @default(autoincrement())
  ordenCompraId  Int    @map("orden_compra_id")
  productoId     Int    @map("producto_id")
  cantidadPedida Float  @map("cantidad_pedida")
  unidad         String
  precioEstimado Float? @map("precio_estimado")

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  producto    Producto    @relation(fields: [productoId], references: [id])

  @@map("orden_compra_items")
}

// ==========================================
// RECEPCIONES (verificación de lo recibido)
// ==========================================
model Recepcion {
  id            Int      @id @default(autoincrement())
  ordenCompraId Int      @map("orden_compra_id")
  fecha         String
  hora          String
  recibidoPorId Int      @map("recibido_por_id")
  observacion   String?
  createdAt     DateTime @default(now()) @map("created_at")

  ordenCompra  OrdenCompra     @relation(fields: [ordenCompraId], references: [id])
  recibidoPor  Usuario         @relation("recepcionUsuario", fields: [recibidoPorId], references: [id])
  items        RecepcionItem[]
  movimientos  Movimiento[]

  @@map("recepciones")
}

model RecepcionItem {
  id               Int     @id @default(autoincrement())
  recepcionId      Int     @map("recepcion_id")
  productoId       Int     @map("producto_id")
  cantidadPedida   Float?  @map("cantidad_pedida")   // copia de la OC al momento de recibir
  cantidadRecibida Float   @map("cantidad_recibida")
  unidad           String
  costoUnitario    Float?  @map("costo_unitario")
  lote             String?
  observacion      String?
  atribucion       String? // 'proveedor' | 'recepcion' | null — a quién se atribuye la diferencia
  motivoDiferencia String? @map("motivo_diferencia")

  recepcion Recepcion @relation(fields: [recepcionId], references: [id], onDelete: Cascade)
  producto  Producto  @relation(fields: [productoId], references: [id])

  @@map("recepcion_items")
}

// ==========================================
// TAREAS (delegación de responsabilidades)
// ==========================================
model Tarea {
  id            Int      @id @default(autoincrement())
  titulo        String
  descripcion   String?
  tipo          String   @default("general") // general, recibir_mercaderia, inventario, limpieza, prep, cierre
  estado        String   @default("pendiente") // pendiente, en_progreso, completada, cancelada
  prioridad     String   @default("normal") // baja, normal, alta, urgente
  fecha         String   // YYYY-MM-DD — para cuándo
  horaLimite    String?  @map("hora_limite") // HH:mm — hora límite opcional
  creadoPorId   Int      @map("creado_por_id")
  asignadoAId   Int      @map("asignado_a_id")
  completadaAt  DateTime? @map("completada_at")
  observacion   String?  // nota al completar
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  creadoPor     Usuario  @relation("tareasCreadas", fields: [creadoPorId], references: [id])
  asignadoA     Usuario  @relation("tareasAsignadas", fields: [asignadoAId], references: [id])

  @@map("tareas")
}
