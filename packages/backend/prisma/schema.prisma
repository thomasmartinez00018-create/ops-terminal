generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANCY — Cuenta / Organizacion / Miembro
// ============================================================================
// - Cuenta: la persona que se loguea con email+password (el dueño / operador
//   de alto nivel). Puede pertenecer a N organizaciones.
// - Organizacion: el workspace. Todos los datos de negocio están scopeados
//   a una organización (productos, depósitos, movimientos, etc.). Es la
//   unidad de facturación y de aislamiento de datos.
// - Miembro: tabla pivote N-a-N entre Cuenta y Organizacion, con el rol que
//   esa cuenta tiene dentro de ese workspace.
// ============================================================================

model Cuenta {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  nombre          String
  emailVerificado Boolean   @default(false) @map("email_verificado")
  ultimoLogin     DateTime? @map("ultimo_login")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  miembros Miembro[]

  @@map("cuentas")
}

model Organizacion {
  id                   Int       @id @default(autoincrement())
  nombre               String
  slug                 String    @unique
  // ── Billing "hot path" ────────────────────────────────────────────────
  // Estos tres campos son los que lee requireSuscripcionActiva en cada
  // request. Son una proyección denormalizada de Suscripcion para evitar
  // un JOIN en el middleware. Los webhooks de Mercado Pago mantienen
  // ambas tablas sincronizadas.
  plan                 String    @default("trial") // trial | basico | pro | pro_anual | enterprise
  estadoSuscripcion    String    @default("trialing") @map("estado_suscripcion") // trialing | active | past_due | paused | canceled | unpaid
  trialHasta           DateTime? @map("trial_hasta")
  // Legacy — se dejan por retrocompat de migrations anteriores. No se usan.
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  // Límites por plan (copia del plan al crear para evitar lookups)
  limiteUsuarios       Int       @default(999) @map("limite_usuarios")
  limiteProductos      Int       @default(99999) @map("limite_productos")
  limiteDepositos      Int       @default(99) @map("limite_depositos")
  // Datos fiscales para facturación electrónica ARCA (WSFEv1)
  razonSocial          String?   @map("razon_social")
  cuit                 String?
  condicionIva         String?   @map("condicion_iva") // responsable_inscripto | monotributo | exento
  domicilioFiscal      String?   @map("domicilio_fiscal")
  // ── Onboarding personalizado ──────────────────────────────────────────
  // JSON stringificado con respuestas del wizard post-signup:
  //   { empleados: 'solo_yo'|'2_5'|'6_15'|'16_mas',
  //     dolor: 'costo_plato'|'merma'|'robo'|'pedidos',
  //     frecuencia: 'todo_dia'|'rato'|'ocasional',
  //     skipped?: true,
  //     version: 1 }
  // Se usa para (a) inyectar contexto al asistente IA y (b) priorizar
  // qué tours/recomendaciones mostrar en el Dashboard. null = wizard no
  // completado todavía (seguimos mostrándolo hasta que responda u omita).
  perfilOnboarding     String?   @map("perfil_onboarding")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  miembros           Miembro[]
  productos          Producto[]
  depositos          Deposito[]
  usuarios           Usuario[]
  movimientos        Movimiento[]
  proveedores        Proveedor[]
  proveedorProductos ProveedorProducto[]
  recetas            Receta[]
  elaboraciones      ElaboracionLote[]
  inventarios        Inventario[]
  ordenesCompra      OrdenCompra[]
  recepciones        Recepcion[]
  tareas             Tarea[]
  facturas           Factura[]
  pagos              Pago[]
  porcionados        Porcionado[]
  listasPrecio       ListaPrecio[]
  stockParametros    StockParametro[]
  ordenesReposicion  OrdenReposicion[]
  alertasPrecio      AlertaPrecio[]
  suscripcion        Suscripcion?

  @@map("organizaciones")
}

model Miembro {
  id             Int      @id @default(autoincrement())
  cuentaId       Int      @map("cuenta_id")
  organizacionId Int      @map("organizacion_id")
  rol            String   @default("owner") // owner | admin | staff
  createdAt      DateTime @default(now()) @map("created_at")

  cuenta       Cuenta       @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  organizacion Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)

  @@unique([cuentaId, organizacionId])
  @@map("miembros")
}

// ==========================================
// DEVICE PAIRING CODES — onboarding de empleados en devices nuevos
// ==========================================
// El admin genera un código de 6 dígitos desde un device ya autenticado.
// El empleado lo ingresa en su propio celular/tablet desde /vincular-dispositivo
// y recibe un token stage 2 (org elegida, sin staff). Después loguea con
// su PIN para subir a stage 3. Así no hay que compartir email+password.
// El código expira a los 10 minutos y es single-use.
// ==========================================
model DevicePairingCode {
  id                Int       @id @default(autoincrement())
  codigo            String    @unique // 6 dígitos
  organizacionId    Int       @map("organizacion_id")
  creadoPorCuentaId Int       @map("creado_por_cuenta_id")
  usado             Boolean   @default(false)
  expiraEn          DateTime  @map("expira_en")
  usadoEn           DateTime? @map("usado_en")
  usadoDesdeIp      String?   @map("usado_desde_ip")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([codigo])
  @@index([organizacionId])
  @@map("device_pairing_codes")
}

// ==========================================
// MAESTRO DE PRODUCTOS
// ==========================================
model Producto {
  id                Int      @id @default(autoincrement())
  organizacionId    Int      @default(0) @map("organizacion_id")
  codigo            String
  nombre            String
  rubro             String // Verduras, Carnes, Lacteos, Bebidas, etc.
  subrubro          String? // Sub-categoría opcional: Chardonnay, Malbec, etc.
  tipo              String // crudo, elaborado, semielaborado, insumo
  unidadCompra      String   @map("unidad_compra") // kg, lt, unidad, caja
  unidadUso         String   @map("unidad_uso") // kg, lt, unidad, porcion
  factorConversion  Float    @default(1) @map("factor_conversion")
  codigoBarras      String?  @map("codigo_barras")
  depositoDefectoId Int?     @map("deposito_defecto_id")
  stockMinimo       Float    @default(0) @map("stock_minimo")
  stockIdeal        Float    @default(0) @map("stock_ideal")
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organizacion        Organizacion          @relation(fields: [organizacionId], references: [id])
  depositoDefecto     Deposito?             @relation(fields: [depositoDefectoId], references: [id])
  movimientos         Movimiento[]
  proveedorProductos  ProveedorProducto[]
  recetaIngredientes  RecetaIngrediente[]
  inventarioDetalles  InventarioDetalle[]
  ordenCompraItems    OrdenCompraItem[]
  recepcionItems      RecepcionItem[]
  recetasResultado    Receta[]              @relation("recetaProducto")
  elaboraciones       ElaboracionLote[]     @relation("elaborProducto")
  facturaItems        FacturaItem[]
  porcionadosOrigen   Porcionado[]          @relation("porcionadoOrigen")
  porcionadoItems     PorcionadoItem[]
  stockParametros     StockParametro[]
  ordenReposicionItem OrdenReposicionItem[]
  alertasPrecio       AlertaPrecio[]

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("productos")
}

// ==========================================
// DEPÓSITOS
// ==========================================
model Deposito {
  id               Int     @id @default(autoincrement())
  organizacionId   Int     @default(0) @map("organizacion_id")
  codigo           String
  nombre           String
  tipo             String? // almacen, cocina, barra, freezer, camara, seco
  // Jerarquía opcional: el depósito padre es el que "abastece" a éste.
  // Permite modelar cadenas tipo Garage → Gamuza → Barra (N niveles, no
  // hardcoded 3). El motor de reposición sugiere transferencias siguiendo
  // esta cadena cuando un depósito cae por debajo del punto de reposición.
  depositoPadreId  Int?    @map("deposito_padre_id")
  activo           Boolean @default(true)

  organizacion       Organizacion       @relation(fields: [organizacionId], references: [id])
  productos          Producto[]
  movimientosOrigen  Movimiento[]       @relation("depositoOrigen")
  movimientosDestino Movimiento[]       @relation("depositoDestino")
  inventarios        Inventario[]
  ordenesCompra      OrdenCompra[]      @relation("ocDeposito")
  usuariosDefecto    Usuario[]          @relation("usuarioDepositoDefecto")
  elaboraciones      ElaboracionLote[]  @relation("elaborDeposito")
  porcionadosOrigen  Porcionado[]       @relation("porcionadoDepOrigen")
  porcionadoItemsDep PorcionadoItem[]   @relation("porcionadoItemDep")
  // Árbol: padre / hijos (self-relation)
  depositoPadre      Deposito?          @relation("DepositoJerarquia", fields: [depositoPadreId], references: [id])
  depositosHijos     Deposito[]         @relation("DepositoJerarquia")
  // Parámetros de reposición por producto × depósito
  stockParametros    StockParametro[]
  // Reposiciones donde este depósito es origen / destino
  reposicionesOrigen  OrdenReposicion[] @relation("reposicionOrigen")
  reposicionesDestino OrdenReposicion[] @relation("reposicionDestino")

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@index([depositoPadreId])
  @@map("depositos")
}

// ==========================================
// USUARIOS (staff interno — código + PIN para el POS)
// ==========================================
// Un Usuario es un operador del restaurante (cajero, cocinero, depósito…).
// Se identifica con código + PIN, no con email. Pertenece a una sola
// organización (si el mismo humano trabaja en dos restos del mismo dueño,
// crea dos Usuarios, uno por org).
model Usuario {
  id             Int     @id @default(autoincrement())
  organizacionId Int     @default(0) @map("organizacion_id")
  codigo         String
  nombre         String
  rol            String // admin, cocina, deposito, barra, compras
  pin            String?
  activo         Boolean @default(true)
  permisos       String  @default("[]") // JSON array de claves de secciones habilitadas
  configuracion  String? // JSON: { tipo, widgets, acciones } — config de dashboard por usuario

  depositoDefectoId Int?      @map("deposito_defecto_id")
  depositoDefecto   Deposito? @relation("usuarioDepositoDefecto", fields: [depositoDefectoId], references: [id])

  organizacion           Organizacion      @relation(fields: [organizacionId], references: [id])
  movimientos            Movimiento[]      @relation("movUsuario")
  movimientosResponsable Movimiento[]      @relation("movResponsable")
  inventarios            Inventario[]
  ordenesCreadas         OrdenCompra[]     @relation("ocCreador")
  ordenesAsignadas       OrdenCompra[]     @relation("ocResponsable")
  recepciones            Recepcion[]       @relation("recepcionUsuario")
  tareasCreadas          Tarea[]           @relation("tareasCreadas")
  tareasAsignadas        Tarea[]           @relation("tareasAsignadas")
  elaboraciones          ElaboracionLote[] @relation("elaborUsuario")
  porcionados            Porcionado[]      @relation("porcionadoUsuario")
  facturasCreadas        Factura[]         @relation("facturaCreador")
  pagosCreados           Pago[]            @relation("pagoCreador")
  reposicionesCreadas    OrdenReposicion[] @relation("repoCreador")
  reposicionesAsignadas  OrdenReposicion[] @relation("repoAsignado")
  reposicionesEjecutadas OrdenReposicion[] @relation("repoEjecutor")
  alertasPrecioRevisadas AlertaPrecio[]    @relation("alertaPrecioRevisor")

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("usuarios")
}

// ==========================================
// MOVIMIENTOS (corazón del sistema)
// ==========================================
model Movimiento {
  id                Int      @id @default(autoincrement())
  organizacionId    Int      @default(0) @map("organizacion_id")
  fecha             String // YYYY-MM-DD
  hora              String // HH:mm
  usuarioId         Int      @map("usuario_id")
  tipo              String // ingreso, elaboracion, merma, transferencia, ajuste, conteo, consumo_interno, devolucion
  depositoOrigenId  Int?     @map("deposito_origen_id")
  depositoDestinoId Int?     @map("deposito_destino_id")
  productoId        Int      @map("producto_id")
  cantidad          Float
  unidad            String
  lote              String?
  motivo            String?
  // Categoría de merma — solo relevante cuando tipo='merma' o 'consumo_interno'.
  // Permite distinguir merma "buena" (preparación normal, cáscara) de merma
  // "mala" (vencimiento, rotura) y de la que el dueño debería auditar
  // (cortesía, staff meal, sin explicación). El dashboard agrupa por esta
  // categoría para que salga a la luz el robo hormiga vs la pérdida natural.
  //   'preparacion' — cáscara, hueso, recorte (esperada según receta/merma)
  //   'vencimiento' — se venció antes de usarse
  //   'rotura'      — se rompió, se cayó
  //   'cortesia'    — regalo al cliente/amigo
  //   'staff_meal'  — comida del personal
  //   'sin_explicacion' — no sabe qué pasó (flag crítico)
  categoriaMerma    String?  @map("categoria_merma")
  costoUnitario     Float?   @map("costo_unitario")
  proveedorId       Int?     @map("proveedor_id")
  documentoRef      String?  @map("documento_ref")
  observacion       String?
  responsableId     Int?     @map("responsable_id")
  recepcionId       Int?     @map("recepcion_id")
  elaboracionLoteId Int?     @map("elaboracion_lote_id")
  facturaId         Int?     @map("factura_id")
  porcionadoId      Int?     @map("porcionado_id")
  createdAt         DateTime @default(now()) @map("created_at")

  organizacion    Organizacion     @relation(fields: [organizacionId], references: [id])
  usuario         Usuario          @relation("movUsuario", fields: [usuarioId], references: [id])
  responsable     Usuario?         @relation("movResponsable", fields: [responsableId], references: [id])
  depositoOrigen  Deposito?        @relation("depositoOrigen", fields: [depositoOrigenId], references: [id])
  depositoDestino Deposito?        @relation("depositoDestino", fields: [depositoDestinoId], references: [id])
  producto        Producto         @relation(fields: [productoId], references: [id])
  proveedor       Proveedor?       @relation(fields: [proveedorId], references: [id])
  recepcion       Recepcion?       @relation(fields: [recepcionId], references: [id])
  elaboracionLote ElaboracionLote? @relation(fields: [elaboracionLoteId], references: [id])
  factura         Factura?         @relation(fields: [facturaId], references: [id])
  porcionado      Porcionado?      @relation(fields: [porcionadoId], references: [id])

  @@index([organizacionId])
  @@index([organizacionId, fecha])
  @@map("movimientos")
}

// ==========================================
// PROVEEDORES
// ==========================================
model Proveedor {
  id             Int     @id @default(autoincrement())
  organizacionId Int     @default(0) @map("organizacion_id")
  codigo         String
  nombre         String
  contacto       String?
  telefono       String?
  email          String?
  rubro          String?
  activo         Boolean @default(true)

  descuentoPct     Float   @default(0) @map("descuento_pct")
  aplicaIva        Boolean @default(false) @map("aplica_iva")
  aplicaPercepcion Boolean @default(false) @map("aplica_percepcion")
  impuestoInterno  Float   @default(0) @map("impuesto_interno")
  whatsapp         String?

  organizacion       Organizacion        @relation(fields: [organizacionId], references: [id])
  movimientos        Movimiento[]
  proveedorProductos ProveedorProducto[]
  ordenesCompra      OrdenCompra[]
  facturas           Factura[]
  listasPrecio       ListaPrecio[]
  alertasPrecio      AlertaPrecio[]

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("proveedores")
}

// ==========================================
// PRODUCTOS DEL PROVEEDOR (normalización)
// ==========================================
model ProveedorProducto {
  id               Int     @id @default(autoincrement())
  organizacionId   Int     @default(0) @map("organizacion_id")
  proveedorId      Int     @map("proveedor_id")
  productoId       Int     @map("producto_id")
  nombreProveedor  String  @map("nombre_proveedor") // "Papa negra x 10kg"
  codigoProveedor  String? @map("codigo_proveedor")
  unidadProveedor  String? @map("unidad_proveedor")
  factorConversion Float   @default(1) @map("factor_conversion")
  ultimoPrecio     Float?  @map("ultimo_precio")
  fechaPrecio      String? @map("fecha_precio")

  organizacion     Organizacion      @relation(fields: [organizacionId], references: [id])
  proveedor        Proveedor         @relation(fields: [proveedorId], references: [id])
  producto         Producto          @relation(fields: [productoId], references: [id])
  listaPrecioItems ListaPrecioItem[]

  @@index([organizacionId])
  @@map("proveedor_productos")
}

// ==========================================
// RECETAS
// ==========================================
model Receta {
  id                  Int     @id @default(autoincrement())
  organizacionId      Int     @default(0) @map("organizacion_id")
  codigo              String
  nombre              String
  categoria           String? // entrada, plato, postre, bebida
  sector              String? // pizzeria, cocina, pasteleria, pastas
  porciones           Int     @default(1)
  productoResultadoId Int?    @map("producto_resultado_id")
  cantidadProducida   Float?  @map("cantidad_producida")
  unidadProducida     String? @map("unidad_producida")
  activo              Boolean @default(true)
  // ── Pricing (opcional) ───────────────────────────────────────────────
  // precioVenta: lo que cobra el restaurante por porción al cliente.
  // margenObjetivo: % de margen bruto que el dueño considera sano
  // (default 70% = food cost del 30%, el benchmark del rubro).
  // Cuando el costo sube y el margen cae bajo este número, la app
  // alerta para actualizar precio.
  precioVenta         Float?  @map("precio_venta")
  margenObjetivo      Float?  @default(70) @map("margen_objetivo")
  // ── Salida a carta ───────────────────────────────────────────────────
  // `true` = es un plato que va al menú del cliente (ej: Milanesa con
  // papas, Ensalada César). `false` = preparación intermedia que NO sale
  // a la carta (ej: Masa de factura, Fondo de vegetales). Permite separar
  // en reportes y UI los platos finales de las sub-preparaciones.
  salidaACarta        Boolean @default(false) @map("salida_a_carta")
  // ── Ficha técnica (opcional, feature 3) ──────────────────────────────
  // Campos para convertir la receta en una ficha técnica completa que
  // el chef pueda imprimir y pegar en la pared de la cocina.
  metodoPreparacion   String? @map("metodo_preparacion")
  tiempoPreparacion   Int?    @map("tiempo_preparacion") // minutos
  notasChef           String? @map("notas_chef")
  imagenBase64        String? @map("imagen_base64") // base64 comprimido, ~80KB

  organizacion      Organizacion        @relation(fields: [organizacionId], references: [id])
  ingredientes      RecetaIngrediente[]
  elaboraciones     ElaboracionLote[]
  productoResultado Producto?           @relation("recetaProducto", fields: [productoResultadoId], references: [id])

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("recetas")
}

// ==========================================
// INGREDIENTES DE RECETA
// (child de Receta — no necesita organizacion_id, se filtra por parent)
// ==========================================
model RecetaIngrediente {
  id            Int    @id @default(autoincrement())
  recetaId      Int    @map("receta_id")
  productoId    Int    @map("producto_id")
  cantidad      Float
  unidad        String
  mermaEsperada Float  @default(0) @map("merma_esperada") // porcentaje

  receta   Receta   @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@map("receta_ingredientes")
}

// ==========================================
// ELABORACION LOTES
// ==========================================
model ElaboracionLote {
  id                  Int      @id @default(autoincrement())
  organizacionId      Int      @default(0) @map("organizacion_id")
  codigo              String
  fecha               String
  hora                String
  usuarioId           Int      @map("usuario_id")
  recetaId            Int?     @map("receta_id")
  sector              String? // pizzeria, cocina, pasteleria, pastas
  productoResultadoId Int      @map("producto_resultado_id")
  cantidadProducida   Float    @map("cantidad_producida")
  unidadProducida     String   @map("unidad_producida")
  depositoDestinoId   Int?     @map("deposito_destino_id")
  observacion         String?
  createdAt           DateTime @default(now()) @map("created_at")

  organizacion      Organizacion @relation(fields: [organizacionId], references: [id])
  usuario           Usuario      @relation("elaborUsuario", fields: [usuarioId], references: [id])
  receta            Receta?      @relation(fields: [recetaId], references: [id])
  productoResultado Producto     @relation("elaborProducto", fields: [productoResultadoId], references: [id])
  depositoDestino   Deposito?    @relation("elaborDeposito", fields: [depositoDestinoId], references: [id])
  movimientos       Movimiento[]
  porcionados       Porcionado[]

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("elaboracion_lotes")
}

// ==========================================
// PORCIONADO (elaboración base → sub-productos)
// ==========================================
// Toma un producto elaborado (ej: masa) y lo divide en N sub-productos
// (ej: bollo grande, bollo chico, bollo individual) con peso por unidad.
model Porcionado {
  id                Int      @id @default(autoincrement())
  organizacionId    Int      @default(0) @map("organizacion_id")
  codigo            String // POR-001
  fecha             String
  hora              String
  usuarioId         Int      @map("usuario_id")
  elaboracionLoteId Int?     @map("elaboracion_lote_id") // vínculo opcional a la elaboración origen
  productoOrigenId  Int      @map("producto_origen_id") // producto que se porciona (ej: masa)
  cantidadOrigen    Float    @map("cantidad_origen") // cantidad total de entrada
  unidadOrigen      String   @map("unidad_origen") // kg, lt, etc.
  depositoOrigenId  Int?     @map("deposito_origen_id")
  merma             Float    @default(0) // desperdicio durante porcionado
  observacion       String?
  createdAt         DateTime @default(now()) @map("created_at")

  organizacion    Organizacion     @relation(fields: [organizacionId], references: [id])
  usuario         Usuario          @relation("porcionadoUsuario", fields: [usuarioId], references: [id])
  elaboracionLote ElaboracionLote? @relation(fields: [elaboracionLoteId], references: [id])
  productoOrigen  Producto         @relation("porcionadoOrigen", fields: [productoOrigenId], references: [id])
  depositoOrigen  Deposito?        @relation("porcionadoDepOrigen", fields: [depositoOrigenId], references: [id])
  items           PorcionadoItem[]
  movimientos     Movimiento[]

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("porcionados")
}

model PorcionadoItem {
  id                Int    @id @default(autoincrement())
  porcionadoId      Int    @map("porcionado_id")
  productoId        Int    @map("producto_id")
  cantidad          Float // cuántas unidades salen
  pesoUnidad        Float  @map("peso_unidad") // peso por unidad (ej: 0.3 kg por bollo)
  unidad            String // unidad del producto (kg, unidad, etc.)
  depositoDestinoId Int?   @map("deposito_destino_id")

  porcionado      Porcionado @relation(fields: [porcionadoId], references: [id], onDelete: Cascade)
  producto        Producto   @relation(fields: [productoId], references: [id])
  depositoDestino Deposito?  @relation("porcionadoItemDep", fields: [depositoDestinoId], references: [id])

  @@map("porcionado_items")
}

// ==========================================
// INVENTARIOS / CONTEOS
// ==========================================
model Inventario {
  id             Int      @id @default(autoincrement())
  organizacionId Int      @default(0) @map("organizacion_id")
  fecha          String // YYYY-MM-DD
  usuarioId      Int      @map("usuario_id")
  depositoId     Int      @map("deposito_id")
  estado         String   @default("abierto") // abierto, cerrado
  observacion    String?
  createdAt      DateTime @default(now()) @map("created_at")

  organizacion Organizacion        @relation(fields: [organizacionId], references: [id])
  usuario      Usuario             @relation(fields: [usuarioId], references: [id])
  deposito     Deposito            @relation(fields: [depositoId], references: [id])
  detalles     InventarioDetalle[]

  @@index([organizacionId])
  @@map("inventarios")
}

model InventarioDetalle {
  id             Int     @id @default(autoincrement())
  inventarioId   Int     @map("inventario_id")
  productoId     Int     @map("producto_id")
  cantidadFisica Float   @map("cantidad_fisica")
  stockTeorico   Float?  @map("stock_teorico")
  diferencia     Float? // fisica - teorica
  observacion    String?

  inventario Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  producto   Producto   @relation(fields: [productoId], references: [id])

  @@map("inventario_detalles")
}

// ==========================================
// ÓRDENES DE COMPRA
// ==========================================
model OrdenCompra {
  id                Int      @id @default(autoincrement())
  organizacionId    Int      @default(0) @map("organizacion_id")
  codigo            String // OC-001 (único dentro de la org)
  fecha             String // YYYY-MM-DD
  estado            String   @default("pendiente") // pendiente, parcial, recibida, cancelada
  proveedorId       Int      @map("proveedor_id")
  creadoPorId       Int      @map("creado_por_id")
  responsableId     Int      @map("responsable_id")
  depositoDestinoId Int?     @map("deposito_destino_id")
  observacion       String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organizacion    Organizacion      @relation(fields: [organizacionId], references: [id])
  proveedor       Proveedor         @relation(fields: [proveedorId], references: [id])
  creadoPor       Usuario           @relation("ocCreador", fields: [creadoPorId], references: [id])
  responsable     Usuario           @relation("ocResponsable", fields: [responsableId], references: [id])
  depositoDestino Deposito?         @relation("ocDeposito", fields: [depositoDestinoId], references: [id])
  items           OrdenCompraItem[]
  recepciones     Recepcion[]
  facturas        Factura[]

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("ordenes_compra")
}

model OrdenCompraItem {
  id             Int    @id @default(autoincrement())
  ordenCompraId  Int    @map("orden_compra_id")
  productoId     Int    @map("producto_id")
  cantidadPedida Float  @map("cantidad_pedida")
  unidad         String
  precioEstimado Float? @map("precio_estimado")

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  producto    Producto    @relation(fields: [productoId], references: [id])

  @@map("orden_compra_items")
}

// ==========================================
// RECEPCIONES (verificación de lo recibido)
// ==========================================
model Recepcion {
  id             Int      @id @default(autoincrement())
  organizacionId Int      @default(0) @map("organizacion_id")
  ordenCompraId  Int      @map("orden_compra_id")
  fecha          String
  hora           String
  recibidoPorId  Int      @map("recibido_por_id")
  observacion    String?
  createdAt      DateTime @default(now()) @map("created_at")

  organizacion Organizacion    @relation(fields: [organizacionId], references: [id])
  ordenCompra  OrdenCompra     @relation(fields: [ordenCompraId], references: [id])
  recibidoPor  Usuario         @relation("recepcionUsuario", fields: [recibidoPorId], references: [id])
  items        RecepcionItem[]
  movimientos  Movimiento[]

  @@index([organizacionId])
  @@map("recepciones")
}

model RecepcionItem {
  id               Int     @id @default(autoincrement())
  recepcionId      Int     @map("recepcion_id")
  productoId       Int     @map("producto_id")
  cantidadPedida   Float?  @map("cantidad_pedida") // copia de la OC al momento de recibir
  cantidadRecibida Float   @map("cantidad_recibida")
  unidad           String
  costoUnitario    Float?  @map("costo_unitario")
  lote             String?
  observacion      String?
  atribucion       String? // 'proveedor' | 'recepcion' | null — a quién se atribuye la diferencia
  motivoDiferencia String? @map("motivo_diferencia")

  recepcion Recepcion @relation(fields: [recepcionId], references: [id], onDelete: Cascade)
  producto  Producto  @relation(fields: [productoId], references: [id])

  @@map("recepcion_items")
}

// ==========================================
// TAREAS (delegación de responsabilidades)
// ==========================================
model Tarea {
  id             Int       @id @default(autoincrement())
  organizacionId Int       @default(0) @map("organizacion_id")
  titulo         String
  descripcion    String?
  tipo           String    @default("general") // general, recibir_mercaderia, inventario, limpieza, prep, cierre
  estado         String    @default("pendiente") // pendiente, en_progreso, completada, cancelada
  prioridad      String    @default("normal") // baja, normal, alta, urgente
  fecha          String // YYYY-MM-DD — para cuándo
  horaLimite     String?   @map("hora_limite") // HH:mm — hora límite opcional
  creadoPorId    Int       @map("creado_por_id")
  asignadoAId    Int       @map("asignado_a_id")
  completadaAt   DateTime? @map("completada_at")
  observacion    String? // nota al completar
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organizacion Organizacion @relation(fields: [organizacionId], references: [id])
  creadoPor    Usuario      @relation("tareasCreadas", fields: [creadoPorId], references: [id])
  asignadoA    Usuario      @relation("tareasAsignadas", fields: [asignadoAId], references: [id])

  @@index([organizacionId])
  @@map("tareas")
}

// ==========================================
// FACTURAS RECIBIDAS (contabilidad)
// ==========================================
model Factura {
  id               Int      @id @default(autoincrement())
  organizacionId   Int      @default(0) @map("organizacion_id")
  codigo           String // FAC-001 auto (único dentro de la org)
  tipoComprobante  String   @map("tipo_comprobante") // "A","B","C","ticket","remito"
  numero           String // nro original del proveedor
  fecha            String // YYYY-MM-DD fecha de emisión
  fechaVencimiento String?  @map("fecha_vencimiento") // YYYY-MM-DD fecha de pago
  proveedorId      Int      @map("proveedor_id")
  ordenCompraId    Int?     @map("orden_compra_id")
  subtotal         Float    @default(0)
  iva              Float    @default(0)
  total            Float    @default(0)
  estado           String   @default("pendiente") // pendiente|parcial|pagada|anulada
  imagenBase64     String?  @map("imagen_base64")
  observacion      String?
  creadoPorId      Int      @map("creado_por_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organizacion Organizacion  @relation(fields: [organizacionId], references: [id])
  proveedor    Proveedor     @relation(fields: [proveedorId], references: [id])
  ordenCompra  OrdenCompra?  @relation(fields: [ordenCompraId], references: [id])
  creadoPor    Usuario       @relation("facturaCreador", fields: [creadoPorId], references: [id])
  items        FacturaItem[]
  pagos        Pago[]
  movimientos  Movimiento[]
  alertasPrecio AlertaPrecio[]

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("facturas")
}

model FacturaItem {
  id             Int    @id @default(autoincrement())
  facturaId      Int    @map("factura_id")
  productoId     Int?   @map("producto_id")
  descripcion    String
  cantidad       Float
  unidad         String
  precioUnitario Float  @map("precio_unitario")
  alicuotaIva    Float  @default(21) @map("alicuota_iva") // 0, 10.5, 21, 27
  subtotal       Float  @default(0)
  iva            Float  @default(0)

  factura  Factura   @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [productoId], references: [id])

  @@map("factura_items")
}

// ==========================================
// PAGOS (contra facturas)
// ==========================================
model Pago {
  id             Int      @id @default(autoincrement())
  organizacionId Int      @default(0) @map("organizacion_id")
  facturaId      Int      @map("factura_id")
  fecha          String // YYYY-MM-DD
  monto          Float
  medioPago      String   @map("medio_pago") // efectivo|transferencia|cheque|debito|credito
  referencia     String?
  observacion    String?
  creadoPorId    Int      @map("creado_por_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organizacion Organizacion @relation(fields: [organizacionId], references: [id])
  factura      Factura      @relation(fields: [facturaId], references: [id])
  creadoPor    Usuario      @relation("pagoCreador", fields: [creadoPorId], references: [id])

  @@index([organizacionId])
  @@map("pagos")
}

// ==========================================
// LISTAS DE PRECIOS (importación de proveedores)
// ==========================================
model ListaPrecio {
  id             Int      @id @default(autoincrement())
  organizacionId Int      @default(0) @map("organizacion_id")
  codigo         String // LP-001 auto
  proveedorId    Int      @map("proveedor_id")
  fecha          String // YYYY-MM-DD
  archivoOrigen  String?  @map("archivo_origen")
  estado         String   @default("pendiente") // pendiente|procesada|archivada
  createdAt      DateTime @default(now()) @map("created_at")

  organizacion Organizacion      @relation(fields: [organizacionId], references: [id])
  proveedor    Proveedor         @relation(fields: [proveedorId], references: [id])
  items        ListaPrecioItem[]

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@map("listas_precio")
}

model ListaPrecioItem {
  id                   Int     @id @default(autoincrement())
  listaPrecioId        Int     @map("lista_precio_id")
  productoOriginal     String  @map("producto_original")
  codigoOriginal       String? @map("codigo_original") // SKU del proveedor (columna CODIGO del XLSX). Puede coincidir con Producto.codigo interno cuando el proveedor exporta desde Maxirest u otra fuente que usa los mismos códigos del cliente.
  presentacionOriginal String? @map("presentacion_original")
  tipoCompra           String  @default("UNIDAD") @map("tipo_compra") // UNIDAD|CAJA
  unidadesPorCaja      Int     @default(1) @map("unidades_por_caja")
  cantidadPorUnidad    Float?  @map("cantidad_por_unidad")
  unidadMedida         String? @map("unidad_medida")
  precioInformado      Float   @map("precio_informado")
  precioPorUnidad      Float?  @map("precio_por_unidad")
  precioPorMedidaBase  Float?  @map("precio_por_medida_base")
  moneda               String  @default("ARS")
  proveedorProductoId  Int?    @map("proveedor_producto_id")
  estadoMatch          String  @default("PENDIENTE") @map("estado_match") // PENDIENTE|OK
  activo               Boolean @default(true)

  listaPrecio       ListaPrecio        @relation(fields: [listaPrecioId], references: [id], onDelete: Cascade)
  proveedorProducto ProveedorProducto? @relation(fields: [proveedorProductoId], references: [id])

  @@map("lista_precio_items")
}

// ============================================================================
// SUSCRIPCIONES / BILLING
// ============================================================================
// Una Suscripcion por organización (relación 1:1 opcional). Contiene los
// datos específicos del proveedor de pago (Mercado Pago hoy, Stripe en el
// futuro), el ciclo de facturación y metadata de trial. Los campos
// "hot path" (plan, estado, trialHasta) se replican en Organizacion para
// que el middleware de request no tenga que hacer JOIN.
// ============================================================================
model Suscripcion {
  id             Int    @id @default(autoincrement())
  organizacionId Int    @unique @map("organizacion_id")
  proveedor      String @default("mercadopago") // mercadopago | stripe
  plan           String // basico | pro | pro_anual | enterprise
  estado         String // trial | active | past_due | paused | cancelled | expired
  precioMensual  Float  @default(0) @map("precio_mensual") // ARS
  moneda         String @default("ARS")
  frecuencia     String @default("mensual") // mensual | anual

  // Mercado Pago — Preapproval Plan API
  mpPreapprovalPlanId String? @map("mp_preapproval_plan_id") // plan template creado en MP
  mpPreapprovalId     String? @map("mp_preapproval_id") // subscripción concreta del usuario
  mpPayerId           String? @map("mp_payer_id") // ID del payer en MP
  mpPayerEmail        String? @map("mp_payer_email")
  mpInitPoint         String? @map("mp_init_point") // URL de checkout para autorizar

  // Ciclo de vida
  trialInicio         DateTime? @map("trial_inicio")
  trialFin            DateTime? @map("trial_fin")
  periodoActualInicio DateTime? @map("periodo_actual_inicio")
  periodoActualFin    DateTime? @map("periodo_actual_fin")
  proximoCobroEn      DateTime? @map("proximo_cobro_en")
  canceladaEn         DateTime? @map("cancelada_en")
  motivoCancelacion   String?   @map("motivo_cancelacion")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizacion Organizacion      @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  pagos        PagoSuscripcion[]

  @@index([mpPreapprovalId])
  @@map("suscripciones")
}

// ============================================================================
// PAGOS DE SUSCRIPCIÓN (historial de cobros)
// ============================================================================
// Un registro por cada intento de cobro que hace Mercado Pago contra la
// tarjeta asociada al preapproval. El webhook crea/actualiza filas acá.
// El campo `facturado` + `cae` permiten trackear qué pagos ya emitieron
// factura electrónica via ARCA (integración futura).
// ============================================================================
model PagoSuscripcion {
  id            Int       @id @default(autoincrement())
  suscripcionId Int       @map("suscripcion_id")
  mpPaymentId   String?   @unique @map("mp_payment_id") // payment ID de MP
  monto         Float
  moneda        String    @default("ARS")
  estado        String // pending | approved | rejected | refunded | cancelled | in_process
  metodoPago    String?   @map("metodo_pago") // credit_card | debit_card | ticket | account_money
  ultimos4      String?   @map("ultimos_4") // últimos 4 de la tarjeta, para mostrar en UI
  marca         String? // visa | master | amex
  referencia    String? // external_reference
  fechaPago     DateTime? @map("fecha_pago")
  periodoDesde  DateTime? @map("periodo_desde")
  periodoHasta  DateTime? @map("periodo_hasta")

  // Facturación electrónica ARCA (futuro)
  facturado     Boolean   @default(false)
  cae           String? // CAE devuelto por ARCA
  caeVence      DateTime? @map("cae_vence")
  facturaNumero String?   @map("factura_numero") // nro de comprobante emitido
  facturaPdfUrl String?   @map("factura_pdf_url")

  rawPayload String? // JSON raw del webhook (debug)
  createdAt  DateTime @default(now()) @map("created_at")

  suscripcion Suscripcion @relation(fields: [suscripcionId], references: [id], onDelete: Cascade)

  @@index([suscripcionId])
  @@map("pagos_suscripcion")
}

// ==========================================
// STOCK PARÁMETROS (por producto × depósito)
// ==========================================
// Parámetros de reposición a nivel fino: mínimo, objetivo y punto de
// reposición específicos para un producto en un depósito particular.
// Cuando no existe una fila para un (producto, depósito), el motor de
// reposición usa como fallback los valores globales en `Producto`
// (stockMinimo / stockIdeal). Esto permite empezar a usar la feature sin
// configurar nada y refinar por depósito a medida que se usa.
//
// - stockMinimo: por debajo de esto, alerta + sugerencia de reposición
// - stockObjetivo: cantidad "ideal" (techo del refill). El motor sugiere
//   llevar al depósito desde su punto actual hasta este valor.
// - puntoReposicion: umbral que dispara la sugerencia. Suele estar entre
//   mínimo y objetivo; si es null, se usa stockMinimo como disparador.
// ==========================================
model StockParametro {
  id              Int      @id @default(autoincrement())
  organizacionId  Int      @default(0) @map("organizacion_id")
  productoId      Int      @map("producto_id")
  depositoId      Int      @map("deposito_id")
  stockMinimo     Float?   @map("stock_minimo")
  stockObjetivo   Float?   @map("stock_objetivo")
  puntoReposicion Float?   @map("punto_reposicion")
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organizacion Organizacion @relation(fields: [organizacionId], references: [id])
  producto     Producto     @relation(fields: [productoId], references: [id])
  deposito     Deposito     @relation(fields: [depositoId], references: [id])

  @@unique([organizacionId, productoId, depositoId])
  @@index([organizacionId])
  @@index([depositoId])
  @@map("stock_parametros")
}

// ==========================================
// ÓRDENES DE REPOSICIÓN (transferencias internas sugeridas)
// ==========================================
// Las órdenes de compra (OrdenCompra) son hacia PROVEEDORES externos.
// Las órdenes de reposición son transferencias INTERNAS entre depósitos,
// típicamente de un depósito "padre" (Garage, almacén central) hacia un
// depósito "hijo" (Gamuza, cocina, barra). El motor las SUGIERE cuando
// el depósito hijo baja del punto de reposición; un humano las confirma
// ajustando cantidades antes de que se ejecuten. Al confirmar+ejecutar,
// se crea un Movimiento de `transferencia` por cada item — el stock real
// se sigue calculando on-demand desde la tabla movimientos.
//
// Estados:
//   - sugerida   → el motor la propuso, esperando confirmación humana
//   - pendiente  → humano la confirmó y asignó, aún sin ejecutar
//   - ejecutada  → las cantidades se transfirieron (Movimiento creados)
//   - cancelada  → se descartó antes de ejecutar
// ==========================================
model OrdenReposicion {
  id                Int      @id @default(autoincrement())
  organizacionId    Int      @default(0) @map("organizacion_id")
  codigo            String // OR-001 (único dentro de la org)
  fecha             String // YYYY-MM-DD en que se generó
  estado            String   @default("sugerida") // sugerida | pendiente | ejecutada | cancelada
  depositoOrigenId  Int      @map("deposito_origen_id")
  depositoDestinoId Int      @map("deposito_destino_id")
  motivo            String? // "Punto de reposición" | "Manual" | "Cadena Garage→Gamuza→Barra"
  creadoPorId       Int      @map("creado_por_id")
  asignadoAId       Int?     @map("asignado_a_id")
  ejecutadoPorId    Int?     @map("ejecutado_por_id")
  fechaEjecucion    String?  @map("fecha_ejecucion")
  observacion       String?
  generadoAuto      Boolean  @default(false) @map("generado_auto") // true si lo creó el motor
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organizacion    Organizacion @relation(fields: [organizacionId], references: [id])
  depositoOrigen  Deposito     @relation("reposicionOrigen", fields: [depositoOrigenId], references: [id])
  depositoDestino Deposito     @relation("reposicionDestino", fields: [depositoDestinoId], references: [id])
  creadoPor       Usuario      @relation("repoCreador", fields: [creadoPorId], references: [id])
  asignadoA       Usuario?     @relation("repoAsignado", fields: [asignadoAId], references: [id])
  ejecutadoPor    Usuario?     @relation("repoEjecutor", fields: [ejecutadoPorId], references: [id])
  items           OrdenReposicionItem[]

  @@unique([organizacionId, codigo])
  @@index([organizacionId])
  @@index([organizacionId, estado])
  @@map("ordenes_reposicion")
}

model OrdenReposicionItem {
  id                 Int    @id @default(autoincrement())
  ordenReposicionId  Int    @map("orden_reposicion_id")
  productoId         Int    @map("producto_id")
  cantidadSugerida   Float  @map("cantidad_sugerida")
  cantidadConfirmada Float? @map("cantidad_confirmada")
  unidad             String
  stockOrigenSnapshot  Float? @map("stock_origen_snapshot") // foto del stock al generar
  stockDestinoSnapshot Float? @map("stock_destino_snapshot")
  observacion        String?

  ordenReposicion OrdenReposicion @relation(fields: [ordenReposicionId], references: [id], onDelete: Cascade)
  producto        Producto        @relation(fields: [productoId], references: [id])

  @@index([ordenReposicionId])
  @@map("orden_reposicion_items")
}

// ==========================================
// ALERTAS DE PRECIO — detección automática de variaciones
// ==========================================
// Se genera una alerta cada vez que se confirma una factura (escaneada o
// manual) y algún item tiene un precioUnitario distinto al histórico del
// mismo producto × proveedor. El sistema no bloquea nada — solo registra,
// categoriza por severidad y notifica en la UI (toast post-confirm + badge
// persistente en sidebar). El usuario la revisa y la marca como
// 'revisada' (aceptada) o 'descartada' (error de OCR / ignorar).
// ==========================================
model AlertaPrecio {
  id               Int      @id @default(autoincrement())
  organizacionId   Int      @default(0) @map("organizacion_id")
  productoId       Int      @map("producto_id")
  proveedorId      Int?     @map("proveedor_id")
  facturaId        Int?     @map("factura_id")
  facturaItemId    Int?     @map("factura_item_id") // ref al item puntual, si está
  precioAnterior   Float    @map("precio_anterior")
  precioNuevo      Float    @map("precio_nuevo")
  variacionPct     Float    @map("variacion_pct")    // signed: +15.2 = subió, -8.1 = bajó
  severidad        String   @default("leve")          // leve | media | alta
  direccion        String   @default("sube")          // sube | baja
  unidad           String?
  fuenteAnterior   String?  @map("fuente_anterior")   // "factura" | "proveedor_producto" | "lista_precio"
  fechaAnterior    String?  @map("fecha_anterior")    // fecha del precio previo, si disponible
  estado           String   @default("pendiente")     // pendiente | revisada | descartada
  revisadoPorId    Int?     @map("revisado_por_id")
  fechaRevision    DateTime? @map("fecha_revision")
  observacion      String?
  createdAt        DateTime @default(now()) @map("created_at")

  organizacion Organizacion @relation(fields: [organizacionId], references: [id])
  producto     Producto     @relation(fields: [productoId], references: [id])
  proveedor    Proveedor?   @relation(fields: [proveedorId], references: [id])
  factura      Factura?     @relation(fields: [facturaId], references: [id], onDelete: SetNull)
  revisadoPor  Usuario?     @relation("alertaPrecioRevisor", fields: [revisadoPorId], references: [id])

  @@index([organizacionId])
  @@index([estado])
  @@index([productoId])
  @@map("alertas_precio")
}
