{
  "name": "ops-terminal",
  "version": "1.0.0",
  "description": "OPS Terminal — Sistema de gestión de stock para restaurantes y proveedores gastronómicos",
  "author": {
    "name": "Más Orgánicos",
    "email": "contacto@masorganicos.com.ar"
  },
  "homepage": "https://github.com/thomasmartinez00018-create/ops-terminal",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasmartinez00018-create/ops-terminal.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "publish": null,
    "appId": "com.masorganicos.opsterminal",
    "productName": "OPS Terminal",
    "copyright": "Copyright © 2026 Más Orgánicos. Todos los derechos reservados.",
    "directories": {
      "output": "../../dist-electron"
    },
    "files": [
      "main.js",
      "loading.html",
      "error.html",
      "license.txt",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!prisma/libquery_engine-darwin*",
          "!prisma/libquery_engine-linux*",
          "!@prisma/fetch-engine/**",
          "!@prisma/debug/**",
          "!@prisma/get-platform/**",
          "!@prisma/config/**",
          "!**/.cache/**",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**",
          "!**/*.md",
          "!**/.git/**"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/node_modules/.prisma",
        "to": "backend/node_modules/.prisma",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/prisma/data/stock-gastro.db",
        "to": "template.db"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "publisherName": "Más Orgánicos",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "signingHashAlgorithms": ["sha256"],
      "artifactName": "OPS-Terminal-Setup-${version}.${ext}",
      "legalTrademarks": "OPS Terminal™",
      "fileAssociations": []
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OPS Terminal",
      "uninstallDisplayName": "OPS Terminal — Más Orgánicos",
      "license": "license.txt",
      "deleteAppDataOnUninstall": false,
      "packElevateHelper": false,
      "include": "installer.nsh",
      "warningsAsErrors": false
    }
  },
  "devDependencies": {
    "electron": "32.3.3",
    "electron-builder": "24.13.3"
  }
}
