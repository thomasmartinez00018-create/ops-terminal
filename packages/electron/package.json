{
  "name": "ops-terminal",
  "version": "2.1.2",
  "description": "OPS Terminal — Sistema de gestión de stock para restaurantes y proveedores gastronómicos",
  "author": {
    "name": "Más Orgánicos",
    "email": "contacto@masorganicos.com.ar"
  },
  "homepage": "https://github.com/thomasmartinez00018-create/ops-terminal",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasmartinez00018-create/ops-terminal.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "publish": null,
    "appId": "com.masorganicos.opsterminal",
    "productName": "OPS Terminal",
    "copyright": "Copyright © 2026 Más Orgánicos. Todos los derechos reservados.",
    "directories": {
      "output": "../../dist-electron"
    },
    "files": [
      "main.js",
      "loading.html",
      "error.html",
      "license.txt",
      "package.json",
      "assets/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Más Orgánicos",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "signingHashAlgorithms": ["sha256"],
      "artifactName": "OPS-Terminal-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OPS Terminal",
      "uninstallDisplayName": "OPS Terminal - Mas Organicos",
      "license": "license.txt",
      "deleteAppDataOnUninstall": false,
      "packElevateHelper": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "installer.nsh",
      "warningsAsErrors": false
    },
    "asar": true,
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "npmRebuild": false
  },
  "devDependencies": {
    "electron": "32.3.3",
    "electron-builder": "24.13.3"
  }
}
